{
  "name": "@tractus/outbox-prisma",
  "version": "0.1.0",
  "description": "Prisma storage adapter for Tractus Outbox pattern.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist.index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tractus/core": "workspace:*"
  },
  "peerDependencies": {
    "@prisma/client": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
