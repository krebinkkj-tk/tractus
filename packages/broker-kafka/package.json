{
  "name": "@tractus/broker-kafka",
  "version": "0.0.0",
  "description": "Kafka message broker adapter for Tractus Outbox pattern.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tractus/core": "workspace:*"
  },
  "peerDependencies": {
    "kafkajs": "^2.0.0"
  },
  "devDependencies": {
    "kafkajs": "^2.2.4",
    "tsup": "^8.5.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
