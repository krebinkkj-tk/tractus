{
  "name": "tractus-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "prisma generate && tsc --build",
    "build": "yarn workspaces foreach --all --parallel --topological run build"
  },
  "packageManager": "yarn@4.12.0",
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/node": "^25.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
